---
// Ethos section — arch visual + philosophy text
---

<section class="ethos" id="about">
  <div class="ethos-visual reveal">
    <div class="ethos-arch">
      <div class="ethos-arch-inner">
        <div class="ethos-arch-quote">
          "Health is wealth, and healing is always available to us when we return to the innate
          intelligence of the body."
        </div>
        <div class="ethos-arch-flash">
          <span class="word-flash">Nutrition</span> is healing.
        </div>
      </div>
    </div>
  </div>
  <div class="ethos-content reveal">
    <div class="section-tag">About Challis</div>
    <h2>A fresh perspective<br />on <em>General Practice</em></h2>
    <p>
      Dr Challis Paterson combines <strong>conventional medical expertise</strong> with an
      integrative understanding of health — recognising that optimal wellbeing encompasses an entire
      way of life, not a quick fix.
    </p>
    <p>
      With a background spanning the <strong>Mater Hospital</strong>, <strong>Queensland
      Children's Hospital</strong>, and paediatric surgery, Challis brings deep clinical experience
      to her integrative practice. Her philosophy centres on addressing <strong>root causes</strong>
      rather than simply managing symptoms.
    </p>
    <p>
      Having navigated her own health challenges, Challis understands that <strong>knowledge is
      empowering</strong> — therefore patient education is a fundamental cornerstone of every consultation.
    </p>
    <div class="credentials-row">
      <span class="cred"><span class="cred-dot"></span>FRACGP (2025)</span>
      <span class="cred"><span class="cred-dot"></span>Doctor of Medicine, UQ</span>
      <span class="cred"><span class="cred-dot"></span>BExNutrSci, UQ</span>
    </div>
  </div>
</section>

<style>
  .ethos {
    padding: 7rem 5rem;
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 5rem;
    align-items: center;
    position: relative;
  }

  .ethos::before {
    content: '';
    position: absolute;
    right: -10%;
    top: 10%;
    width: 35vw;
    height: 35vw;
    border-radius: 50%;
    background: radial-gradient(circle, var(--peach-light) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .ethos-visual {
    position: relative;
    z-index: 1;
  }

  .ethos-arch {
    width: 100%;
    aspect-ratio: 4/5;
    border-radius: 24px;
    background: var(--terra);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 3rem;
  }

  .ethos-arch-inner {
    text-align: center;
    color: var(--white);
    z-index: 1;
  }

  .ethos-arch-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    font-weight: 300;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 1.5rem;
  }

  .ethos-arch-flash {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.6rem, 2.5vw, 2rem);
    font-weight: 400;
    color: var(--white);
    line-height: 1.2;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: 1.2rem;
  }

  .word-flash {
    color: var(--peach-light);
    display: inline-block;
    transition: opacity 0.4s ease;
  }

  .ethos-content {
    position: relative;
    z-index: 1;
  }

  .ethos-content h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 2.6rem);
    font-weight: 400;
    line-height: 1.2;
    color: var(--charcoal);
    margin-bottom: 1.5rem;
  }

  .ethos-content h2 em {
    color: var(--terra);
    font-style: italic;
  }

  .ethos-content p {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--text-light);
    font-weight: 300;
    margin-bottom: 1rem;
  }

  .ethos-content p strong {
    font-weight: 500;
    color: var(--text);
  }

  .credentials-row {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  .cred {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-light);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .cred-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--terra-light);
  }

  @media (max-width: 900px) {
    .ethos {
      grid-template-columns: 1fr;
      padding: 4rem 2rem;
      gap: 3rem;
    }
  }
</style>

<script>
  const words = [
    'Nutrition',
    'Sunlight',
    'Movement',
    'Rest',
    'Play',
    'Hydration',
    'Connection',
    'Sleep',
  ];

  const el = document.querySelector('.word-flash') as HTMLElement | null;
  if (el) {
    let i = 1;
    setInterval(() => {
      el.style.opacity = '0';
      setTimeout(() => {
        el.textContent = words[i];
        el.style.opacity = '1';
        i = (i + 1) % words.length;
      }, 400);
    }, 2200);
  }
</script>
