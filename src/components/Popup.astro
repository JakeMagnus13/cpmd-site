---
// Welcome popup — triggers 2s after page load, once per 7 days
// Submits to /api/subscribe which forwards to MailerLite
---

<div class="popup-overlay" id="popupOverlay">
  <div class="popup">
    <button class="popup-close" id="popupCloseBtn" aria-label="Close popup">&times;</button>

    <div class="popup-visual">
      <div class="popup-visual-inner">
        <div class="popup-tag">Important Notice</div>
        <h3>Dr Challis is currently <em>on leave</em></h3>
        <p>Join the newsletter to be the first to know when bookings reopen.</p>
      </div>
    </div>

    <div class="popup-form" id="popupForm">
      <div class="popup-notice">
        <div class="popup-notice-label">Important Notice</div>
        <div class="popup-notice-text">
          Dr Challis is on leave from [DATE] to [DATE]. Sign up below to get updates and be
          the first to know when bookings reopen.
        </div>
      </div>

      <h2>Stay <em>connected</em></h2>
      <p>Pop in your details and I'll keep you updated on my return and share occasional notes on integrative health.</p>

      <ul class="popup-benefits">
        <li>Updates on when I'm back seeing patients</li>
        <li>Occasional notes on integrative health — no spam, ever</li>
      </ul>

      <form id="subscribeForm">
        <div class="popup-field">
          <input type="text" name="name" placeholder="Your first name" required />
        </div>
        <div class="popup-field">
          <input type="email" name="email" placeholder="Your email address" required />
        </div>
        <div class="popup-error" id="popupError"></div>
        <button type="submit" class="popup-submit" id="popupSubmitBtn">
          Keep Me Updated →
        </button>
      </form>
      <p class="popup-disclaimer">
        By signing up you agree to receive emails from Dr Challis Paterson. You can unsubscribe
        anytime. <a href="/privacy">Privacy Policy</a>
      </p>
    </div>

    <div class="popup-form popup-success" id="popupSuccess">
      <div class="popup-success-icon">✓</div>
      <h3>You're <em>in</em>!</h3>
      <p>
        You're on the list. I'll keep you updated on my return and share occasional notes on
        integrative health.
      </p>
      <button class="popup-submit" id="popupContinueBtn">Continue Exploring</button>
    </div>
  </div>
</div>

<style>
  .popup-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(45, 42, 38, 0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }

  .popup-overlay.active {
    opacity: 1;
    visibility: visible;
  }

  .popup {
    background: var(--cream);
    border-radius: 28px;
    max-width: 820px;
    width: 100%;
    max-height: 92vh;
    overflow-y: auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    position: relative;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.25);
    transform: scale(0.94) translateY(20px);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .popup-overlay.active .popup {
    transform: scale(1) translateY(0);
  }

  .popup-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    font-weight: 300;
    color: var(--text);
    z-index: 5;
    transition: all 0.3s;
    font-family: var(--font-body);
  }

  .popup-close:hover {
    background: var(--white);
    transform: rotate(90deg);
  }

  .popup-visual {
    background: var(--terra);
    padding: 3rem 2rem;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    color: var(--white);
  }

  .popup-visual::before {
    content: '';
    position: absolute;
    top: -30%;
    right: -30%;
    width: 140%;
    height: 140%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 60%);
    pointer-events: none;
  }

  .popup-visual-inner {
    position: relative;
    z-index: 1;
  }

  .popup-tag {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--peach-light);
    font-weight: 500;
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .popup-tag::before {
    content: '';
    width: 20px;
    height: 1.5px;
    background: var(--peach-light);
  }

  .popup-visual h3 {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.9rem;
    line-height: 1.15;
    font-weight: 400;
    margin-bottom: 1rem;
  }

  .popup-visual p {
    font-size: 0.88rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.8);
    font-weight: 300;
  }

  .popup-guide-preview {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 16px;
    padding: 1.2rem;
    margin-top: 1.5rem;
    position: relative;
    z-index: 1;
    backdrop-filter: blur(10px);
  }

  .popup-guide-preview-label {
    font-size: 0.68rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--peach-light);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .popup-guide-preview-title {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 0.4rem;
  }

  .popup-guide-preview-sub {
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 300;
  }

  .popup-guide-preview-icon {
    position: absolute;
    top: 1.2rem;
    right: 1.2rem;
    font-size: 1.4rem;
  }

  .popup-form {
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .popup-notice {
    background: var(--sage-pale);
    border-left: 3px solid var(--sage);
    padding: 0.9rem 1rem;
    border-radius: 0 10px 10px 0;
    margin-bottom: 1.5rem;
  }

  .popup-notice-label {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sage-deep);
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .popup-notice-text {
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--text);
    font-weight: 400;
  }

  .popup-form h2 {
    font-family: var(--font-display);
    font-size: 1.65rem;
    font-weight: 400;
    color: var(--charcoal);
    line-height: 1.2;
    margin-bottom: 0.7rem;
  }

  .popup-form h2 em {
    color: var(--terra);
    font-style: italic;
  }

  .popup-form > p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text-light);
    font-weight: 300;
    margin-bottom: 1.5rem;
  }

  .popup-benefits {
    list-style: none;
    margin-bottom: 1.5rem;
  }

  .popup-benefits li {
    font-size: 0.85rem;
    color: var(--text);
    font-weight: 400;
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-bottom: 0.6rem;
    line-height: 1.5;
  }

  .popup-benefits li::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--terra);
    flex-shrink: 0;
    margin-top: 0.5rem;
  }

  .popup-field {
    margin-bottom: 0.9rem;
  }

  .popup-field input {
    width: 100%;
    padding: 0.85rem 1.1rem;
    border: 1.5px solid var(--sand);
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--text);
    background: var(--white);
    transition: border 0.3s;
  }

  .popup-field input:focus {
    outline: none;
    border-color: var(--terra);
  }

  .popup-field input::placeholder {
    color: var(--text-light);
    font-weight: 300;
  }

  .popup-error {
    font-size: 0.8rem;
    color: #c44747;
    margin-bottom: 0.5rem;
    min-height: 1.2em;
  }

  .popup-submit {
    width: 100%;
    padding: 0.95rem 1.5rem;
    background: var(--terra);
    color: var(--white);
    border: none;
    border-radius: 12px;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }

  .popup-submit:hover:not(:disabled) {
    background: var(--terra-deep);
    transform: translateY(-1px);
    box-shadow: 0 8px 25px rgba(196, 122, 90, 0.3);
  }

  .popup-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .popup-disclaimer {
    font-size: 0.72rem;
    color: var(--text-light);
    font-weight: 300;
    text-align: center;
    margin-top: 1rem;
    line-height: 1.5;
  }

  .popup-disclaimer a {
    color: var(--terra);
    text-decoration: none;
  }

  .popup-success {
    display: none;
    text-align: center;
    padding: 1rem 0;
  }

  .popup-success.active {
    display: block;
  }

  .popup-success-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--sage-pale);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.2rem;
    font-size: 1.8rem;
    color: var(--sage-deep);
  }

  .popup-success h3 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    color: var(--charcoal);
    margin-bottom: 0.6rem;
  }

  .popup-success h3 em {
    color: var(--terra);
    font-style: italic;
  }

  .popup-success p {
    font-size: 0.9rem;
    color: var(--text-light);
    font-weight: 300;
    line-height: 1.6;
    margin-bottom: 1.2rem;
  }

  .popup-form.hidden {
    display: none;
  }

  @media (max-width: 720px) {
    .popup {
      grid-template-columns: 1fr;
      max-height: 95vh;
    }
    .popup-visual {
      padding: 2rem 1.8rem 1.5rem;
    }
    .popup-visual h3 {
      font-size: 1.5rem;
    }
    .popup-form {
      padding: 1.8rem 1.8rem 2rem;
    }
    .popup-form h2 {
      font-size: 1.4rem;
    }
    .popup-guide-preview {
      padding: 1rem;
    }
  }
</style>

<script>
  const overlay = document.getElementById('popupOverlay');
  const form = document.getElementById('subscribeForm') as HTMLFormElement | null;
  const formWrap = document.getElementById('popupForm');
  const success = document.getElementById('popupSuccess');
  const closeBtn = document.getElementById('popupCloseBtn');
  const continueBtn = document.getElementById('popupContinueBtn');
  const submitBtn = document.getElementById('popupSubmitBtn') as HTMLButtonElement | null;
  const errorEl = document.getElementById('popupError');

  const STORAGE_KEY = 'cpmd_popup_dismissed';
  const DISMISS_DAYS = 7;

  function hasBeenDismissed(): boolean {
    try {
      const dismissedAt = localStorage.getItem(STORAGE_KEY);
      if (!dismissedAt) return false;
      const daysAgo = (Date.now() - parseInt(dismissedAt, 10)) / (1000 * 60 * 60 * 24);
      return daysAgo < DISMISS_DAYS;
    } catch {
      return false;
    }
  }

  function rememberDismissal(): void {
    try {
      localStorage.setItem(STORAGE_KEY, Date.now().toString());
    } catch {
      /* ignore storage errors */
    }
  }

  function openPopup(): void {
    overlay?.classList.add('active');
    document.body.style.overflow = 'hidden';
  }

  function closePopup(): void {
    overlay?.classList.remove('active');
    document.body.style.overflow = '';
    rememberDismissal();
  }

  // Show popup 2s after load, once per 7 days
  if (!hasBeenDismissed()) {
    setTimeout(openPopup, 2000);
  }

  closeBtn?.addEventListener('click', closePopup);
  continueBtn?.addEventListener('click', closePopup);

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closePopup();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('active')) closePopup();
  });

  // Form submission → Cloudflare Function → MailerLite
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !errorEl) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    errorEl.textContent = '';

    const formData = new FormData(form);
    const payload = {
      name: formData.get('name') as string,
      email: formData.get('email') as string,
    };

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || 'Something went wrong. Please try again.');
      }

      formWrap?.classList.add('hidden');
      success?.classList.add('active');
      rememberDismissal();
    } catch (err) {
      errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send Me The Guide →';
    }
  });
</script>
