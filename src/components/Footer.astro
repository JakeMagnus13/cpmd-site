---
// Footer component
const year = new Date().getFullYear();
---

<footer id="contact">
  <div class="footer-grid">
    <div>
      <div class="footer-brand">CPMD <span>.health</span></div>
      <p class="footer-tagline">
        Dr Challis Paterson — Integrative GP in Mount Samson and online. Whole-person,
        root-cause medicine.
      </p>
      <div class="footer-social">
        <a href="#" aria-label="Instagram">IG</a>
        <a href="#" aria-label="Facebook">FB</a>
      </div>
    </div>
    <div>
      <h4>Quick Links</h4>
      <ul>
        <li><a href="/about">About Challis</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/locations">Locations</a></li>
        <li><a href="/blog">Blog</a></li>
      </ul>
    </div>
    <div>
      <h4>Clinics</h4>
      <ul>
        <li><a href="https://www.verawellness.com.au/" target="_blank" rel="noopener">Vera Wellness — Mount Samson</a></li>
        <li><a href="/locations">Online — Australia-wide</a></li>
      </ul>
    </div>
    <div>
      <h4>Get in Touch</h4>
      <ul>
        <li><a href="mailto:hello@cpmd.health">hello@cpmd.health</a></li>
        <li>Mount Samson: 07 2000 1099</li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; {year} CPMD.health — Dr Challis Paterson. All rights reserved.</p>
    <p><a href="/privacy">Privacy Policy</a> · <a href="/terms">Terms</a></p>
  </div>
</footer>

<style>
  footer {
    padding: 4rem 5rem 2rem;
    background: var(--cream);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--terra);
    margin-bottom: 0.8rem;
  }

  .footer-brand span {
    color: var(--sage-deep);
    font-style: italic;
    font-weight: 400;
    font-size: 0.8em;
  }

  .footer-tagline {
    font-size: 0.9rem;
    color: var(--text-light);
    font-weight: 300;
    line-height: 1.6;
    max-width: 280px;
    margin-bottom: 1.2rem;
  }

  .footer-social {
    display: flex;
    gap: 0.8rem;
  }

  .footer-social a {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--sand);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text);
    transition: all 0.3s;
  }

  .footer-social a:hover {
    background: var(--terra-pale);
    color: var(--terra);
  }

  footer h4 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: var(--charcoal);
    margin-bottom: 1rem;
  }

  footer ul {
    list-style: none;
  }

  footer ul li {
    margin-bottom: 0.6rem;
    font-size: 0.88rem;
    color: var(--text-light);
    font-weight: 300;
  }

  footer ul a {
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.3s;
  }

  footer ul a:hover {
    color: var(--terra);
  }

  .footer-bottom {
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding-top: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-bottom p {
    font-size: 0.78rem;
    color: var(--text-light);
    font-weight: 300;
  }

  .footer-bottom a {
    color: var(--terra);
    text-decoration: none;
  }

  @media (max-width: 900px) {
    footer {
      padding: 3rem 2rem 2rem;
    }
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
</style>
