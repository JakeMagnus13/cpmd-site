---
// Welcome popup — triggers 2s after page load, once per 7 days
// Submits to /api/subscribe which forwards to MailerLite
---

<div class="popup-overlay" id="popupOverlay">
  <div class="popup" id="popupCard">
    <button class="popup-close" id="popupCloseBtn" aria-label="Close popup">&times;</button>

    <!-- Main form view -->
    <div class="popup-inner" id="popupForm">
      <div class="popup-info">
        <div class="popup-tag">Important Notice</div>
        <h2>Dr Challis is currently <em>on leave</em></h2>
        <p>Sign up to be the first to know when bookings reopen.</p>
      </div>

      <form class="popup-fields" id="subscribeForm">
        <input type="text" name="name" placeholder="First name" required />
        <input type="email" name="email" placeholder="Email address" required />
        <button type="submit" class="popup-submit" id="popupSubmitBtn">
          Keep Me Updated →
        </button>
        <div class="popup-error" id="popupError"></div>
      </form>
    </div>

    <!-- Success view -->
    <div class="popup-success" id="popupSuccess">
      <div class="popup-success-icon">✓</div>
      <div class="popup-success-text">
        <h3>You're <em>in</em>!</h3>
        <p>I'll be in touch when bookings reopen.</p>
      </div>
      <button class="popup-submit popup-continue" id="popupContinueBtn">Close</button>
    </div>
  </div>
</div>

<style>
  .popup-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(45, 42, 38, 0.45);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .popup-overlay.visible {
    display: flex;
  }

  .popup-overlay.active {
    opacity: 1;
  }

  .popup {
    background: var(--cream);
    border-radius: 20px;
    max-width: 860px;
    width: 100%;
    position: relative;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    transform: scale(0.96) translateY(12px);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }

  .popup-overlay.active .popup {
    transform: scale(1) translateY(0);
  }

  .popup-close {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.06);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--text);
    z-index: 5;
    transition: background 0.2s;
    font-family: var(--font-body);
    line-height: 1;
  }

  .popup-close:hover {
    background: rgba(0, 0, 0, 0.12);
  }

  /* ── Main row layout ── */
  .popup-inner {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    padding: 2rem 2.5rem;
    padding-right: 3.5rem; /* room for close btn */
  }

  .popup-info {
    flex: 0 0 auto;
    max-width: 300px;
  }

  .popup-tag {
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--terra);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .popup-info h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--charcoal);
    line-height: 1.2;
    margin-bottom: 0.4rem;
  }

  .popup-info h2 em {
    color: var(--terra);
    font-style: italic;
  }

  .popup-info p {
    font-size: 0.83rem;
    color: var(--text-light);
    font-weight: 300;
    line-height: 1.5;
    margin: 0;
  }

  /* ── Inline form ── */
  .popup-fields {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .popup-fields input {
    flex: 1;
    min-width: 130px;
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--sand);
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: var(--text);
    background: var(--white);
    transition: border 0.2s;
  }

  .popup-fields input:focus {
    outline: none;
    border-color: var(--terra);
  }

  .popup-fields input::placeholder {
    color: var(--text-light);
    font-weight: 300;
  }

  .popup-submit {
    white-space: nowrap;
    padding: 0.75rem 1.4rem;
    background: var(--terra);
    color: var(--white);
    border: none;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .popup-submit:hover:not(:disabled) {
    background: var(--terra-deep);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(196, 122, 90, 0.3);
  }

  .popup-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .popup-error {
    flex-basis: 100%;
    font-size: 0.78rem;
    color: #c44747;
    min-height: 1em;
  }

  /* ── Success state ── */
  .popup-success {
    display: none;
    align-items: center;
    gap: 1.2rem;
    padding: 1.8rem 2.5rem;
    padding-right: 3.5rem;
  }

  .popup-success.active {
    display: flex;
  }

  .popup-success-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--sage-pale);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    color: var(--sage-deep);
    flex-shrink: 0;
  }

  .popup-success-text {
    flex: 1;
  }

  .popup-success-text h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--charcoal);
    margin-bottom: 0.2rem;
  }

  .popup-success-text h3 em {
    color: var(--terra);
    font-style: italic;
  }

  .popup-success-text p {
    font-size: 0.85rem;
    color: var(--text-light);
    font-weight: 300;
    margin: 0;
  }

  .popup-continue {
    flex-shrink: 0;
  }

  .popup-inner.hidden {
    display: none;
  }

  /* ── Mobile: stack vertically ── */
  @media (max-width: 640px) {
    .popup-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.2rem;
      padding: 1.8rem 1.5rem;
      padding-top: 2.2rem;
    }

    .popup-info {
      max-width: 100%;
    }

    .popup-fields {
      width: 100%;
    }

    .popup-fields input {
      min-width: 100%;
    }

    .popup-submit {
      width: 100%;
      text-align: center;
      justify-content: center;
    }

    .popup-success {
      flex-direction: column;
      text-align: center;
      padding: 1.8rem 1.5rem;
      padding-top: 2.2rem;
    }
  }
</style>

<script>
  const overlay = document.getElementById('popupOverlay');
  const form = document.getElementById('subscribeForm') as HTMLFormElement | null;
  const formWrap = document.getElementById('popupForm');
  const success = document.getElementById('popupSuccess');
  const closeBtn = document.getElementById('popupCloseBtn');
  const continueBtn = document.getElementById('popupContinueBtn');
  const submitBtn = document.getElementById('popupSubmitBtn') as HTMLButtonElement | null;
  const errorEl = document.getElementById('popupError');

  const STORAGE_KEY = 'cpmd_popup_dismissed';
  const DISMISS_DAYS = 7;

  function hasBeenDismissed(): boolean {
    try {
      const dismissedAt = localStorage.getItem(STORAGE_KEY);
      if (!dismissedAt) return false;
      const daysAgo = (Date.now() - parseInt(dismissedAt, 10)) / (1000 * 60 * 60 * 24);
      return daysAgo < DISMISS_DAYS;
    } catch {
      return false;
    }
  }

  function rememberDismissal(): void {
    try {
      localStorage.setItem(STORAGE_KEY, Date.now().toString());
    } catch {
      /* ignore storage errors */
    }
  }

  function openPopup(): void {
    if (!overlay) return;
    overlay.classList.add('visible');
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        overlay.classList.add('active');
      });
    });
    document.body.style.overflow = 'hidden';
  }

  function closePopup(): void {
    if (!overlay) return;
    overlay.classList.remove('active');
    setTimeout(() => overlay.classList.remove('visible'), 400);
    document.body.style.overflow = '';
    rememberDismissal();
  }

  // Show popup 2s after load, once per 7 days
  if (!hasBeenDismissed()) {
    if (document.readyState === 'complete') {
      setTimeout(openPopup, 2000);
    } else {
      window.addEventListener('load', () => setTimeout(openPopup, 2000), { once: true });
    }
  }

  closeBtn?.addEventListener('click', closePopup);
  continueBtn?.addEventListener('click', closePopup);

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closePopup();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('active')) closePopup();
  });

  // Form submission → Cloudflare Function → MailerLite
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !errorEl) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    errorEl.textContent = '';

    const formData = new FormData(form);
    const payload = {
      name: formData.get('name') as string,
      email: formData.get('email') as string,
    };

    try {
      const res = await fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || 'Something went wrong. Please try again.');
      }

      formWrap?.classList.add('hidden');
      success?.classList.add('active');
      rememberDismissal();
    } catch (err) {
      errorEl.textContent = err instanceof Error ? err.message : 'Something went wrong.';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Keep Me Updated →';
    }
  });
</script>
