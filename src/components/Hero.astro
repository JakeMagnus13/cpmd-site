---
// Hero section — terracotta background, arched photo frame, floating credential badges
---

<section class="hero">
  <div class="hero-content">
    <div class="hero-tag">Integrative General Practice</div>
    <h1>Medicine that sees<br />the <em>whole</em> you.</h1>
    <p class="hero-sub">
      Dr Challis Paterson is an integrative GP on the Gold Coast and Mount Samson — combining
      conventional medicine with root-cause, whole-person care.
    </p>
    <div class="hero-buttons">
      <a href="/locations" class="btn-hero-primary">Book an Appointment →</a>
      <a href="/about" class="btn-hero-secondary">Learn More</a>
    </div>
  </div>
  <div class="hero-image">
    <div class="hero-photo-frame">
      <div class="hero-photo">
        <img src="/images/IMG_3589.jpeg" alt="Dr Challis Paterson" />
      </div>
      <div class="hero-badge">
        <div class="badge-dot">🎓</div>
        <div class="badge-label">
          FRACGP Qualified<span>Fellow, Royal Australian College of GPs</span>
        </div>
      </div>
      <div class="hero-badge-right">
        <div class="badge-dot">🌿</div>
        <div class="badge-label">
          Root-Cause Medicine<span>Treating causes, not just symptoms</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    background: var(--terra);
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    padding-top: 4.5rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -15%;
    right: -8%;
    width: 55vw;
    height: 55vw;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.07) 0%, transparent 65%);
    pointer-events: none;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 4rem 3rem 4rem 5rem;
    position: relative;
    z-index: 1;
  }

  .hero-tag {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--peach);
    font-weight: 500;
    margin-bottom: 1.8rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.2s forwards;
  }

  .hero-tag::before {
    content: '';
    width: 24px;
    height: 1.5px;
    background: var(--peach);
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 4.2vw, 3.8rem);
    font-weight: 400;
    line-height: 1.15;
    color: var(--white);
    letter-spacing: -0.015em;
    margin-bottom: 1.6rem;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.4s forwards;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--peach-light);
  }

  .hero-sub {
    font-size: 1.05rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.8);
    max-width: 460px;
    margin-bottom: 2.5rem;
    font-weight: 300;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.6s forwards;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: fadeUp 0.8s ease 0.8s forwards;
  }

  .btn-hero-primary {
    background: var(--white);
    color: var(--terra-deep);
    padding: 0.85rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    transition: all 0.3s;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .btn-hero-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .btn-hero-secondary {
    background: transparent;
    color: var(--white);
    padding: 0.85rem 2rem;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 400;
    font-size: 0.92rem;
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    transition: all 0.3s;
  }

  .btn-hero-secondary:hover {
    border-color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.08);
  }

  .hero-image {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 4rem 4rem 2rem;
    position: relative;
    z-index: 1;
  }

  .hero-photo-frame {
    position: relative;
    width: 100%;
    max-width: 400px;
    opacity: 0;
    animation: fadeIn 1s ease 0.5s forwards;
  }

  .hero-photo {
    width: 100%;
    aspect-ratio: 3/4;
    border-radius: 200px 200px 24px 24px;
    position: relative;
    overflow: hidden;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  .hero-badge {
    position: absolute;
    bottom: 2.5rem;
    left: -1.5rem;
    background: var(--white);
    border-radius: 18px;
    padding: 0.9rem 1.2rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    gap: 0.7rem;
    opacity: 0;
    animation: floatIn 0.8s ease 1s forwards;
  }

  .hero-badge-right {
    position: absolute;
    top: 2rem;
    right: -1rem;
    background: var(--white);
    border-radius: 18px;
    padding: 0.9rem 1.2rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
    display: flex;
    align-items: center;
    gap: 0.7rem;
    opacity: 0;
    animation: floatIn 0.8s ease 1.2s forwards;
  }

  .badge-dot {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: var(--sage-pale);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
  }

  .badge-label {
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1.3;
  }

  .badge-label span {
    display: block;
    font-weight: 300;
    color: var(--text-light);
    font-size: 0.72rem;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-bottom: 3rem;
    }
    .hero-content {
      padding: 6rem 2rem 2rem;
    }
    .hero-image {
      padding: 1rem 2rem 3rem;
    }
    .hero-badge,
    .hero-badge-right {
      display: none;
    }
  }
</style>
